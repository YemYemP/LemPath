# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/

# ── Vite / TypeScript caches ──────────────────────────────────────────────────
.vite/
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Test & coverage artifacts ─────────────────────────────────────────────────
coverage/
.nyc_output/
# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/
*.webm
*.zip

# ── Local env & secrets ───────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Package manager lock files (keep only one) ────────────────────────────────
# Uncomment the one you DON'T use:
# yarn.lock
# pnpm-lock.yaml

# ── OS files ──────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
# Linux
*~

# ── Editor & IDE ──────────────────────────────────────────────────────────────
# VS Code (keep shared settings, ignore personal/generated ones)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
# JetBrains
.idea/
*.iml
# Vim / Emacs
*.swp
*.swo
.#*
